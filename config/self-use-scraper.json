{
  "routing": {
    "order": ["A", "B", "C"],
    "maxAttempts": 3,
    "backoffMs": [1000, 2000, 4000],
    "legacyDirectEnabled": true,
    "preRoute": {
      "enabled": true,
      "questionFirstToC": true,
      "questionMarkers": ["?", "？", "what", "how", "why", "when", "where", "which", "谁", "什么", "怎么", "如何", "为何", "为什么", "吗"]
    },
    "circuitBreaker": {
      "failThreshold": 3,
      "cooldownSec": 600,
      "halfOpenSuccessThreshold": 1
    }
  },
  "timeouts": {
    "pageLoadMs": 15000,
    "actionMs": 8000,
    "totalMs": 35000
  },
  "cache": {
    "enabled": true,
    "queryTtlSec": 1200,
    "urlTtlSec": 900
  },
  "rateLimit": {
    "minIntervalMs": 1200,
    "jitterMs": 500
  },
  "output": {
    "mode": "compact",
    "compactTopN": 3,
    "maxSnippetChars": 180,
    "artifactPointer": {
      "enabled": true,
      "dir": "data/runtime/artifacts",
      "summaryMaxChars": 280
    }
  },
  "safety": {
    "allowLoginAutomation": false
  },
  "paths": {
    "runtimeDir": "data/runtime",
    "cacheDir": "data/cache",
    "metricsDir": "logs"
  }
}
