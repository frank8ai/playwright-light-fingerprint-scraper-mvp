NODE_ENV=production
HEADLESS=true
DEFAULT_TIMEOUT_MS=30000
MAX_RETRIES=3
MAX_ATTEMPTS=3
RETRY_BACKOFF_MS=1000
SCREENSHOT_ON_ERROR=true
ENABLE_FINGERPRINT=true
USE_STEALTH=false
STEALTH_LOG=false
PACING_MIN_MS=300
PACING_MAX_MS=1200
PROXY_COOLDOWN_MS=300000
BROWSER_LOCALE=zh-CN
BROWSER_TIMEZONE=Asia/Shanghai
SITE_KEY=site_a
